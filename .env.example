NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://localhost:27017/taskflow
MONGO_URI_TEST=

# Generate strong random values for these, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_access
JWT_REFRESH_SECRET=change_this_to_a_long_random_secret_refresh
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN_MS=604800000

COOKIE_SECRET=change_this_to_a_long_random_secret_cookie

CLIENT_URL=http://localhost:5173
ORIGIN_WHITELIST=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

LOG_LEVEL=info
